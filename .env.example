# PostgreSQL connection string (required). Locally, point this at your own Postgres instance;
# on Render this is auto-injected from the managed database defined in render.yaml.
DATABASE_URL="postgresql://user:password@localhost:5432/market_event_impact?schema=public"

# Standard Next.js/Node environment flag. Render sets this to "production" automatically;
# set to "development" locally (this is also the default if unset).
NODE_ENV="development"

# Cron schedule (standard cron syntax) for the standalone mock-data pipeline job (`npm run cron`).
# Optional — defaults to every 15 minutes if unset.
CRON_SCHEDULE="*/15 * * * *"

# Port the Next.js server listens on (`next start -p $PORT`). Render injects this automatically;
# optional locally — defaults to 3000 if unset.
PORT=3000
